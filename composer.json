{
    "name": "ytgov/lagoon-quitpath-ca",
    "description": "Yukon Government - lobbyist - registry",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "git@github.com:ytgov/lagoon-boutique-base-image.git"
        }
    ],
    "require": {
        "ytgov/lagoon-boutique-base-image": "dev-w3creatives/prod11",
        "drupal/address": "^2.0",
        "drupal/block_class": "^4.0",
        "drupal/quicktabs": "^4.0",
        "drupal/views_fieldsets": "^4.0",
        "drupal/restui": "^1.22",
        "drupal/oauth2_server": "^2.1",
        "drupal/token_filter": "^2.2",
        "drupal/search_api": "^1.40",
        "drupal/translation_views": "^2.0@alpha",
        "drupal/views_field_view": "^1.0@beta",
        "drupal/multiple_registration": "3.x-dev@dev",
        "drupal/csv_serialization": "^4.0",
        "drupal/views_data_export": "^1.8",
        "drupal/webform_views": "^5.6",
        "drupal/telephone_formatter": "^1.3",
        "drupal/consumers": "^1.23",
        "drupal/rest_views": "^3.1",
        "drupal/eck": "^2.1@beta",
        "drupal/webform_content_creator": "^4.0",
        "drupal/views_bootstrap": "^5.5@RC"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/contrib/{$name}": ["type:drupal-drush"]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "excludes": [
                "sites/development.services.yml",
                "sites/example.settings.local.php"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "drupal/core-project-message": false,
            "drupal/core-composer-scaffold": true,
            "cweagans/composer-patches": true,
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
