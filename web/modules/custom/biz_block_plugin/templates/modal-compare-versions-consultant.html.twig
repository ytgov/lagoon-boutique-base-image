{% set modal_id = 'compare-modal-' ~ changes.id|replace({'/':'-'})%}
{% set date_class = changes.data.start_date.class ~ ' ' ~ changes.data.end_date.class %}

<div class="modal fade" tabindex="-1" role="dialog" aria-labelledby="" aria-hidden="true" id={{modal_id}}>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title">{% trans %}Compare{% endtrans %}</h4>
      </div>
      <div class="modal-body">
        <div class="container-fluid">
          <div class="row">
              <div class="col-md-12">
              <div class="col-xs-12 col-md-6">
              <div class="registration-details-old-version">
                <div class="header-view orange-header">
                  <h5>{% trans %}Registration details{% endtrans %}</h5>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Registration number{% endtrans %}</label>
                  <label class="version-info">{{changes.count}}</label>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Changed{% endtrans %}</label>
                  <label class="version-info">{{changes.date}}</label>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Version status{% endtrans %}</label>
                  <label class="version-info">{% trans %}Inactive{% endtrans %}</label>
                </div>
              </div>
              <div class="lobbying-activity-current-version">
                <div class="header-view purple-header">
                  <h5>{% trans %}Lobbying activity{% endtrans %}</h5>
                </div>
                <div class={{changes.data.title.class}}>
                  <label class="version-desc">{% trans %}Project title{% endtrans %}</label>
                  <label class="version-info">{{changes.data.title.value| raw}}</label>
                </div>
                {% if type_lobbyist == 'add_a_lobbying_activity_consulta'%}
                  <div class={{changes.data.org_name.class}}>
                    <label class="version-desc">{% trans %}Organization Name{% endtrans %}</label>
                    <label class="version-info">{{changes.data.org_name.value| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Street address or P.O. Box number{% endtrans %}</label>
                    <label class="version-info">{{changes.data.custom_address.value.address_line1| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}City or town{% endtrans %}</label>
                    <label class="version-info">{{changes.data.custom_address.value.locality| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Country{% endtrans %}</label>
                    <label class="version-info">{{changes.data.custom_address.value.country_code}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Territory, province or state{% endtrans %}</label>
                    <label class="version-info">{{changes.data.custom_address.value.administrative_area| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Postal or zip code{% endtrans %}</label>
                    <label class="version-info">{{changes.data.custom_address.value.postal_code}}</label>
                  </div>
                  <div class={{date_class}}>
                    <label class="version-desc">{% trans %}Dates{% endtrans %}</label>
                    <label class="version-info">{{changes.data.start_date.value}} - {{changes.data.end_date.value}}</label>
                  </div>
                {%endif%}
                {% if type_lobbyist == 'add_a_lobbying_activity'%}
                  <div class={{changes.data.year.class}}>
                    <label class="version-desc">{% trans %}Year{% endtrans %}</label>
                    <label class="version-info">{{changes.data.year.value}}</label>
                  </div>
                {%endif%}
                <div class={{changes.data.which_topic_do_you_want_to_lobby_government_about_.class}}>
                  <label class="version-desc">{% trans %}Topics{% endtrans %}</label>
                  <label class="version-info">{{changes.data.which_topic_do_you_want_to_lobby_government_about_.value| raw}}</label>
                </div>
                 <div class={{changes.data.add_detail.class}}>
                  <label class="version-desc">{% trans %}Details about activity{% endtrans %}</label>
                  <label class="version-info">{{changes.data.add_detail.value| raw}}</label>
                </div>
                 <div class={{changes.data.who_are_you_lobbying_or_plan_to_lobby_.class}}>
                  <label class="version-desc">{% trans %}Who are you lobbying or plan to lobby?{% endtrans %}</label>
                  <label class="version-info">{{changes.data.who_are_you_lobbying_or_plan_to_lobby_.value| raw}}</label>
                </div>
                <div class={{changes.data.how_do_you_want_to_lobby_.class}}>
                  <label class="version-desc">{% trans %}Type of lobbying activity{% endtrans %}</label>
                  <label class="version-info">{{changes.data.how_do_you_want_to_lobby_.value|join(', ')| raw}}</label>
                </div>
                <div class={{changes.data.has_your_organization_received_a_grant_from_the_government_of_yu.class}}>
                  <label class="version-desc">{% trans %}Has the organization you are lobbying on behalf of received a grant from the Government of Yukon within the last year?{% endtrans %}</label>
                  <label class="version-info">{{changes.data.has_your_organization_received_a_grant_from_the_government_of_yu.value| raw}}</label>
                </div>
                <div class={{changes.data.was_the_grant_awarded_related_to_the_matter_the_lobbying_has_bee.class}}>
                  <label class="version-desc">{% trans %}Was the grant awarded related to the matter the lobbying has been or will be undertaken?{% endtrans %}</label>
                  <label class="version-info">{{changes.data.was_the_grant_awarded_related_to_the_matter_the_lobbying_has_bee.value| raw}}</label>
                </div>
              </div>
            </div>
              <div class="col-xs-12 col-md-6">
              <div class="registration-details-current-version">
                <div class="header-view orange-header">
                  <h5>{% trans %}Registration details{% endtrans %}</h5>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Registration number{% endtrans %}</label>
                  <label class="version-info">{{current_version.count}}</label>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Changed{% endtrans %}</label>
                  <label class="version-info">{{current_version.date|replace({'-':'/'}) }}</label>
                </div>
                <div class="changed-info">
                  <label class="version-desc">{% trans %}Version status{% endtrans %}</label>
                  <label class="version-info">{% trans %}Active{% endtrans %}</label>
                </div>
              </div>
              <div class="lobbying-activity-current-version">
                <div class="header-view purple-header">
                  <h5>{% trans %}Lobbying activity{% endtrans %}</h5>
                </div>
                <div class={{changes.data.title.class}}>
                  <label class="version-desc">{% trans %}Project title{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.title| raw}}</label>
                </div>
                {% if type_lobbyist == 'add_a_lobbying_activity_consulta'%}
                  <div class={{changes.data.org_name.class}}>
                    <label class="version-desc">{% trans %}Organization Name{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.org_name| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Street address or P.O. Box number{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.custom_address.address_line1| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}City or town{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.custom_address.locality| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Country{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.custom_address.country_code}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Territory, province or state{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.custom_address.administrative_area| raw}}</label>
                  </div>
                  <div class="">
                    <label class="version-desc">{% trans %}Postal or zip code{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.custom_address.postal_code}}</label>
                  </div>
                  <div class={{date_class}}>
                    <label class="version-desc">{% trans %}Dates{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.start_date}} - {{current_version.data.end_date}}</label>
                  </div>
                {%endif%}
                {% if type_lobbyist == 'add_a_lobbying_activity'%}
                  <div class={{changes.data.year.class}}>
                    <label class="version-desc">{% trans %}Year{% endtrans %}</label>
                    <label class="version-info">{{current_version.data.year}}</label>
                  </div>
                {%endif%}
                <div class={{changes.data.which_topic_do_you_want_to_lobby_government_about_.class}}>
                  <label class="version-desc">{% trans %}Topics{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.which_topic_do_you_want_to_lobby_government_about_| raw}}</label>
                </div>
                 <div class={{changes.data.add_detail.class}}>
                  <label class="version-desc">{% trans %}Details about activity{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.add_detail| raw}}</label>
                </div>
                 <div class={{changes.data.who_are_you_lobbying_or_plan_to_lobby_.class}}>
                  <label class="version-desc">{% trans %}Who are you lobbying or plan to lobby?{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.who_are_you_lobbying_or_plan_to_lobby_| raw}}</label>
                </div>
                <div class={{changes.data.how_do_you_want_to_lobby_.class}}>
                  <label class="version-desc">{% trans %}Type of lobbying activity{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.how_do_you_want_to_lobby_|join(', ')| raw}}</label>
                </div>
                <div class={{changes.data.has_your_organization_received_a_grant_from_the_government_of_yu.class}}>
                  <label class="version-desc">{% trans %}Has the organization you are lobbying on behalf of received a grant from the Government of Yukon within the last year?{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.has_your_organization_received_a_grant_from_the_government_of_yu| raw}}</label>
                </div>
                <div class={{changes.data.was_the_grant_awarded_related_to_the_matter_the_lobbying_has_bee.class}}>
                  <label class="version-desc">{% trans %}Was the grant awarded related to the matter the lobbying has been or will be undertaken?{% endtrans %}</label>
                  <label class="version-info">{{current_version.data.was_the_grant_awarded_related_to_the_matter_the_lobbying_has_bee| raw}}</label>
                </div>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>